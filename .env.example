# Environment Variables — Solar CME Monitor
# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored and must NEVER be committed.

# ─── NASA DONKI API ───────────────────────────────────────────────
# The NASA API key is stored as a Supabase secret (NASA_API_KEY) and
# is injected server-side by the donki-proxy Edge Function.
# If you run without Supabase, the app falls back to DEMO_KEY (30 req/hour).
# VITE_NASA_API_KEY=<not needed — set via: supabase secrets set NASA_API_KEY=...>

# ─── Supabase ──────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
# The anon key is safe to expose client-side (RLS protects the data).
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
